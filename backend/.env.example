# MySQL (required for Hostinger and local dev)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=nature_secret
MYSQL_PASSWORD=nature_secret_dev
MYSQL_DATABASE=nature_secret
# Optional: root password for scripts/setup-local-mysql.sh (local MySQL without Docker)
# MYSQL_ROOT_PASSWORD=

JWT_SECRET=change-this-to-a-long-random-secret-in-production
ENCRYPTION_KEY=change-this-to-32-chars-or-more-in-production
PORT=4000
FRONTEND_ORIGIN=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000

# Review video uploads: set to 1 on the server if `ffmpeg` is installed — re-encodes to H.264 720p-wide + faststart in the background (smoother playback).
# Replacing the file during playback can glitch audio/video; default delay before ffmpeg starts is 90s (override ms below).
# REVIEW_VIDEO_TRANSCODE=1
# REVIEW_VIDEO_TRANSCODE_DELAY_MS=90000
# FFMPEG_PATH=/usr/bin/ffmpeg

# Persistent uploads: set to an absolute path outside the app so product/blog/slider images survive redeploys (e.g. /var/data/nature-secret)
# UPLOAD_ROOT=/var/data/nature-secret

# Gmail (order confirmation email) – use App Password if 2FA enabled
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=

# Twilio (WhatsApp order confirmation + reply-to-confirm)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Webhook auth (WhatsApp incoming): set WEBHOOK_SECRET and send it in header X-Webhook-Secret or Authorization: Bearer <secret>
WEBHOOK_SECRET=

# First-time admin seed: set SETUP_SECRET and call POST /api/v1/setup/seed-admin with header X-Setup-Secret
SETUP_SECRET=

# Firebase Admin (verify customer ID tokens + send FCM). Service account JSON → use these fields.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Meta Conversions API (server-side; same Pixel ID as NEXT_PUBLIC_META_PIXEL_ID on frontend)
META_PIXEL_ID=
META_CONVERSIONS_ACCESS_TOKEN=
# Test Events (CAPI): same string as Events Manager → Test events. Set on API for production CAPI; match NEXT_PUBLIC_META_TEST_EVENT_CODE on web for Pixel.
# Production: without this, CAPI skips test_event_code (unless META_ALLOW_TEST_EVENT_IN_PRODUCTION=true for client-only relay).
# META_TEST_EVENT_CODE=
# META_ALLOW_TEST_EVENT_IN_PRODUCTION=
