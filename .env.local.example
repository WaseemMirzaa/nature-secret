# Full UI catalog + home copy from fixtures (no API). Dev: set to 1. Production: also set NEXT_PUBLIC_UI_MOCK_IN_PRODUCTION=1 if you need demo data on `next start`.
# NEXT_PUBLIC_UI_MOCK=1
# NEXT_PUBLIC_UI_MOCK_IN_PRODUCTION=1

# Point Next.js to the NestJS API (optional; defaults to http://localhost:4000 in lib/api.js)
# For production (naturesecret.pk frontend → shifaefitrat.com API):
# NEXT_PUBLIC_API_URL=https://shifaefitrat.com
NEXT_PUBLIC_API_URL=http://localhost:4000

# API request timeout in ms (5s–300s). Client must use NEXT_PUBLIC_*; optional API_TIMEOUT_MS is server-only fallback for RSC fetches.
# NEXT_PUBLIC_API_TIMEOUT_MS=120000

# Full site URL for correct CSS/JS asset loading behind proxy (e.g. Hostinger). Set in production.
# NEXT_PUBLIC_SITE_URL=https://naturesecret.pk

# Bump this value after each deploy to force one-time cache refresh in browsers.
# Example: NEXT_PUBLIC_APP_VERSION=2026-03-31.1
# NEXT_PUBLIC_APP_VERSION=

# Firebase (customer auth + FCM order notifications). From Firebase Console → Project settings.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional: Web Push key for FCM (Cloud Messaging → Web Push certificates)
# NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Meta Pixel (Events Manager → Settings). Rebuild after changing NEXT_PUBLIC_*.
# NEXT_PUBLIC_META_PIXEL_ID=
# Events Manager → Test events → copy code; remove in production.
# NEXT_PUBLIC_META_TEST_EVENT_CODE=
# Staging/production QA: load Pixel without Meta landing gate (otherwise Test events need fbclid/utm home landing).
# NEXT_PUBLIC_META_OPEN_PIXEL_GATE=true
