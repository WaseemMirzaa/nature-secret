# Point Next.js to the NestJS API (optional; defaults to http://localhost:4000 in lib/api.js)
# For production (naturesecret.pk frontend → shifaefitrat.com API):
# NEXT_PUBLIC_API_URL=https://shifaefitrat.com
NEXT_PUBLIC_API_URL=http://localhost:4000

# Full site URL for correct CSS/JS asset loading behind proxy (e.g. Hostinger). Set in production.
# NEXT_PUBLIC_SITE_URL=https://naturesecret.pk
